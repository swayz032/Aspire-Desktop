"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/admin/ops/sentry/issues":{"get":{"summary":"Sentry Issues","description":"Read-only Sentry issue summaries with deep links.","operationId":"sentry_issues_admin_ops_sentry_issues_get","parameters":[{"name":"limit","in":"query","required":false,"schema":{"type":"integer","maximum":50,"minimum":1,"default":10,"title":"Limit"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/admin/ops/incidents/stream":{"get":{"summary":"Stream Incidents","description":"SSE stream of new incidents and errors.\n\nFrontend consumer: useErrorStream.ts\nEvent shape: {id, severity, message, timestamp, correlation_id, stack_trace, provider}\n\nEnterprise features:\n  - Max 30min stream duration (client reconnects automatically)\n  - Correlation ID on every event for traceability\n  - Rate-limited to 10 events/s\n  - PII redacted (Law #9)\n  - Connection tracked per-tenant (Law #6)","operationId":"stream_incidents_admin_ops_incidents_stream_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/admin/ops/providers/stream":{"get":{"summary":"Stream Provider Health","description":"SSE stream of provider connectivity status.\n\nFrontend consumer: useProviderHealthStream.ts\nEvent shape: ProviderHealth[] (full) or ProviderHealth (single update)","operationId":"stream_provider_health_admin_ops_providers_stream_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/admin/ops/health-pulse/stream":{"get":{"summary":"Stream Health Pulse","description":"SSE stream of aggregate health pulse metrics.\n\nFrontend consumer: Dashboard page (useSSEStream)\nPushes health snapshot every 5s.","operationId":"stream_health_pulse_admin_ops_health_pulse_stream_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/admin/ops/outbox/stream":{"get":{"summary":"Stream Outbox","description":"SSE stream of outbox queue status changes.\n\nFrontend consumer: Outbox page (useSSEStream)\nEmits on state change or every 3s.","operationId":"stream_outbox_admin_ops_outbox_stream_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/admin/ops/council/{session_id}":{"get":{"summary":"Get Council Session","description":"Get council session status and advisor proposals.\n\nFrontend consumer: useCouncilSession.ts (polled, not SSE)\nReturns advisor slots with proposals, confidence, and adjudication.","operationId":"get_council_session_admin_ops_council__session_id__get","parameters":[{"name":"session_id","in":"path","required":true,"schema":{"type":"string","title":"Session Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/admin/ops/voice/stt":{"post":{"summary":"Voice Stt Proxy","description":"Proxy audio to STT service (ElevenLabs Scribe or Deepgram).\n\nFrontend consumer: useElevenLabsSTT.ts\nAccepts audio blob, returns transcript text.","operationId":"voice_stt_proxy_admin_ops_voice_stt_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/admin/ops/voice/tts/stream":{"post":{"summary":"Voice Tts Stream","description":"Stream TTS audio from ElevenLabs.\n\nFrontend consumer: useAdminVoice.ts\nAccepts JSON {text, voice_id?}, streams audio/mpeg chunks.","operationId":"voice_tts_stream_admin_ops_voice_tts_stream_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/admin/ops/chat":{"post":{"summary":"Admin Ava Chat","description":"Ava Admin Chat — streaming LLM endpoint.\n\nStreams Ava admin responses via SSE. Requires admin JWT.\nLaw #1: Brain decides (LLM generates response).\nLaw #2: Receipts emitted for initiation and completion.\nLaw #3: Fail closed on missing auth, API key, or circuit breaker.\nLaw #9: PII redacted on all streamed content.","operationId":"admin_ava_chat_admin_ops_chat_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/robots/ingest":{"post":{"tags":["robots"],"summary":"Robot Ingest","description":"Accept a RobotRun result from CI/CD or the robot runner script.\n\nAuth: HMAC-SHA256 via X-Robot-Signature header.\nFail-closed: missing secret or invalid signature -> 401.","operationId":"robot_ingest_robots_ingest_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/webhooks/stripe":{"post":{"tags":["webhooks"],"summary":"Stripe Webhook","description":"Receive and process Stripe webhook events.\n\nStripe sends events to this endpoint for Connected accounts.\nVerifies signature, deduplicates, emits receipt, returns 200.\n\nReturns 200 even for handled errors (Stripe retries on non-2xx).\nReturns 401 only for signature failures (Stripe should not retry forgeries).","operationId":"stripe_webhook_api_webhooks_stripe_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/webhooks/pandadoc":{"post":{"tags":["webhooks"],"summary":"Pandadoc Webhook","description":"Receive PandaDoc document status webhook events.\n\nPandaDoc sends events for document status changes (viewed, completed, etc).\nVerifies signature, logs event, returns 200.\n\nPhase 2+: Full event processing with receipt emission.","operationId":"pandadoc_webhook_api_webhooks_pandadoc_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/api/webhooks/twilio":{"post":{"tags":["webhooks"],"summary":"Twilio Webhook","description":"Receive Twilio call/SMS status webhook events.\n\nTwilio sends status callbacks for calls and messages.\nVerifies auth token, logs event, returns 200.\n\nPhase 2+: Full event processing with receipt emission.","operationId":"twilio_webhook_api_webhooks_twilio_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/healthz":{"get":{"summary":"Healthz","description":"Liveness probe — always returns ok if process is running.","operationId":"healthz_healthz_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":{"type":"string"},"type":"object","title":"Response Healthz Healthz Get"}}}}}}},"/livez":{"get":{"summary":"Livez","description":"Kubernetes-style liveness probe (alias for /healthz).","operationId":"livez_livez_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":{"type":"string"},"type":"object","title":"Response Livez Livez Get"}}}}}}},"/readyz":{"get":{"summary":"Readyz","description":"Readiness probe — checks critical dependencies are configured and reachable (B-H10).\n\nEnhanced to verify downstream dependencies beyond just configuration:\n- Signing key configured\n- Graph built\n- DLP initialized\n- Receipt store reachable (in-memory always passes; Supabase checked if configured)\n- Redis reachable (if configured)","operationId":"readyz_readyz_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/metrics":{"get":{"summary":"Metrics","description":"Prometheus metrics endpoint (Gate 2: Observability).\n\nSecurity: Only accessible from localhost/internal networks OR with\na valid metrics auth token (ASPIRE_METRICS_TOKEN).\nIn production, Prometheus scrapes from within the private network.","operationId":"metrics_metrics_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/v1/intents":{"post":{"summary":"Process Intent","description":"Process an AvaOrchestratorRequest through the orchestrator graph.\n\nThe graph executes the full pipeline:\nIntake -> Safety -> Policy -> Approval -> TokenMint -> Execute -> ReceiptWrite -> Respond\n\nQuery Parameters:\n    stream: If true, return Server-Sent Events stream with intermediate agent activity (Wave 4).","operationId":"process_intent_v1_intents_post","parameters":[{"name":"stream","in":"query","required":false,"schema":{"type":"boolean","default":false,"title":"Stream"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/receipts":{"get":{"summary":"Get Receipts","description":"Query receipts for a given suite_id with optional filters.\n\nsuite_id is always the auth-derived value from the Gateway.\nThis enforces tenant isolation (Law #6) at the query level.","operationId":"get_receipts_v1_receipts_get","parameters":[{"name":"suite_id","in":"query","required":true,"schema":{"type":"string","description":"Suite ID (from auth, enforced at gateway)","title":"Suite Id"},"description":"Suite ID (from auth, enforced at gateway)"},{"name":"correlation_id","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Correlation Id"}},{"name":"action_type","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Action Type"}},{"name":"risk_tier","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Risk Tier"}},{"name":"limit","in":"query","required":false,"schema":{"type":"integer","maximum":200,"minimum":1,"default":50,"title":"Limit"}},{"name":"offset","in":"query","required":false,"schema":{"type":"integer","minimum":0,"default":0,"title":"Offset"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/tasks/{task_id}/status":{"get":{"summary":"Get Task Status","description":"Query the status of a background task by ID (Phase 4B).","operationId":"get_task_status_v1_tasks__task_id__status_get","parameters":[{"name":"task_id","in":"path","required":true,"schema":{"type":"string","title":"Task Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/receipts/verify-run":{"post":{"summary":"Verify Receipt Chain","description":"Verify receipt hash chain integrity for a correlation_id.\n\nUses the receipt_chain verifier to recompute hashes and detect tampering.\nReturns verification result with chain_length, broken_links, etc.","operationId":"verify_receipt_chain_v1_receipts_verify_run_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/v1/policy/evaluate":{"post":{"summary":"Evaluate Policy","description":"Evaluate policy for an action type without executing.\n\nReturns risk tier, approval requirements, tools, and capability scope.\nUsed by the UI to show risk indicators before user commits.","operationId":"evaluate_policy_v1_policy_evaluate_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/v1/registry/capabilities":{"get":{"summary":"List Capabilities","description":"List all registered capabilities for discovery.\n\nUsed by the UI to show available actions, agents, and risk tiers.\nNo auth required beyond Gateway-level auth (read-only, no tenant secrets).","operationId":"list_capabilities_v1_registry_capabilities_get","parameters":[{"name":"category","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Category"}},{"name":"risk_tier","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Risk Tier"}},{"name":"status","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Status"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/registry/skill-packs/{pack_id}":{"get":{"summary":"Get Skill Pack","description":"Get a specific skill pack manifest.","operationId":"get_skill_pack_v1_registry_skill_packs__pack_id__get","parameters":[{"name":"pack_id","in":"path","required":true,"schema":{"type":"string","title":"Pack Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/registry/route/{action_type}":{"get":{"summary":"Route Action","description":"Route an action_type to the responsible skill pack.\n\nUsed by the orchestrator internally and by clients for preview.","operationId":"route_action_v1_registry_route__action_type__get","parameters":[{"name":"action_type","in":"path","required":true,"schema":{"type":"string","title":"Action Type"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/a2a/dispatch":{"post":{"summary":"A2A Dispatch","description":"Dispatch a task to a skill pack agent.\n\nOnly the orchestrator should call this (Law #1: Single Brain).\nThe Gateway enforces auth; the orchestrator trusts its own internal calls.","operationId":"a2a_dispatch_v1_a2a_dispatch_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/v1/a2a/claim":{"post":{"summary":"A2A Claim","description":"Claim available tasks for an agent.\n\nAgents call this to pull work from the queue.\nTenant-scoped (Law #6).","operationId":"a2a_claim_v1_a2a_claim_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/v1/a2a/complete":{"post":{"summary":"A2A Complete","description":"Mark a claimed task as completed.","operationId":"a2a_complete_v1_a2a_complete_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/v1/a2a/fail":{"post":{"summary":"A2A Fail","description":"Mark a claimed task as failed (may requeue or quarantine).","operationId":"a2a_fail_v1_a2a_fail_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/v1/resume/{approval_id}":{"post":{"summary":"Resume Execution","description":"Resume execution of an approved draft operation.","operationId":"resume_execution_v1_resume__approval_id__post","parameters":[{"name":"approval_id","in":"path","required":true,"schema":{"type":"string","title":"Approval Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/a2a/tasks":{"get":{"summary":"A2A List Tasks","description":"List A2A tasks for a suite with optional filters.","operationId":"a2a_list_tasks_v1_a2a_tasks_get","parameters":[{"name":"suite_id","in":"query","required":true,"schema":{"type":"string","description":"Suite ID (from auth)","title":"Suite Id"},"description":"Suite ID (from auth)"},{"name":"status","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Status"}},{"name":"assigned_to_agent","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Assigned To Agent"}},{"name":"limit","in":"query","required":false,"schema":{"type":"integer","maximum":200,"minimum":1,"default":50,"title":"Limit"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/client/events":{"post":{"summary":"Client Event Ingest","description":"Accept client-side error/event reports (Wave 4I — F7 fix).\n\nAllows the frontend to report errors, blank screens, and UI failures\nso the backend has visibility into client-side problems.\n\nRate limited to 10 events/min per suite (Law #3 — prevent abuse).\nPII redacted from messages (Law #9).","operationId":"client_event_ingest_v1_client_events_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/v1/browser/navigate":{"post":{"summary":"Browser Navigate Endpoint","description":"Navigate browser to URL and capture screenshot (Wave 4).\n\nDirectly invokes browser_service for admin/testing purposes.\nProduction flow: User intent → LangGraph → Adam skill pack → browser_service\n\nRequest body:\n    {\n        \"url\": \"https://www.bing.com/search?q=aspire\",\n        \"suite_id\": \"uuid\",\n        \"viewport_width\": 1280,  // optional\n        \"viewport_height\": 800    // optional\n    }\n\nResponse:\n    {\n        \"success\": true,\n        \"screenshot_id\": \"uuid\",\n        \"screenshot_url\": \"https://s3.../screenshot.png\",\n        \"page_url\": \"https://www.bing.com/search\",  // redacted\n        \"page_title\": \"Bing Search Results\",\n        \"receipt_id\": \"uuid\"\n    }\n\nSecurity:\n    - Domain allowlist enforced (SSRF prevention)\n    - PII redaction on page_url and page_title\n    - Receipt generated for all navigation attempts","operationId":"browser_navigate_endpoint_v1_browser_navigate_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/v1/browser/screenshot/{screenshot_id}":{"get":{"summary":"Get Screenshot Endpoint","description":"Retrieve presigned S3 URL for existing screenshot (Wave 4).\n\nPath params:\n    screenshot_id: UUID of screenshot\n\nResponse:\n    {\n        \"screenshot_url\": \"https://s3.../screenshot.png\",\n        \"expires_at\": 1234567890  // Unix timestamp\n    }\n\nSecurity:\n    - Presigned URL acts as capability token (no additional auth required)\n    - URL expires in 1 hour\n    - S3 path is tenant-scoped (suite_id embedded in S3 key)","operationId":"get_screenshot_endpoint_v1_browser_screenshot__screenshot_id__get","parameters":[{"name":"screenshot_id","in":"path","required":true,"schema":{"type":"string","title":"Screenshot Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"}}}}